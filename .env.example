# Silver Mirror Cancellation Bot — Environment Variables
# Copy this to .env.local for local development
# Add these as Environment Variables in Vercel dashboard for production

# ── REQUIRED ─────────────────────────────────────────────────────

# Anthropic API key (powers the chatbot conversation)
ANTHROPIC_API_KEY=sk-ant-...

# ── BOULEVARD API ────────────────────────────────────────────────

# Boulevard Enterprise API key (for member lookup/authentication)
# If not set, the bot uses mock data for testing
BOULEVARD_API_KEY=
BOULEVARD_BUSINESS_ID=

# ── EMAIL NOTIFICATIONS ──────────────────────────────────────────

# SMTP settings for sending session summaries to memberships@silvermirror.com
# If not set, summaries log to console only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=cancellation-bot@silvermirror.com
EMAIL_TO=memberships@silvermirror.com

# ── GOOGLE SHEETS LOGGING ───────────────────────────────────────

# Google Sheet ID for the cancellation tracking spreadsheet
# Create a sheet with columns: Date, Month, Client Name, Email, Reason, Solution
GOOGLE_SHEET_ID=
# Google Service Account credentials JSON (paste the entire JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── SECURITY ─────────────────────────────────────────────────────

# Allowed origin for CORS (your WordPress domain)
ALLOWED_ORIGIN=https://silvermirror.com
