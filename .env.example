# Silver Mirror Cancellation Bot — Environment Variables
# Copy this to .env.local for local development
# Add these as Environment Variables in Vercel dashboard for production

# ══════════════════════════════════════════════════════════════════
# REQUIRED — App will not function without these
# ══════════════════════════════════════════════════════════════════

# Anthropic API key (powers the Claude chatbot conversation)
ANTHROPIC_API_KEY=sk-ant-...

# ══════════════════════════════════════════════════════════════════
# REQUIRED FOR MEMBER LOOKUP — Needed for Boulevard member search
# Without these, member lookup returns null in production (mock data in dev only)
# ══════════════════════════════════════════════════════════════════

# Boulevard Admin API credentials
# Auth: HMAC-based Basic auth (blvd-admin-v1 signing scheme)
BOULEVARD_API_URL=https://dashboard.boulevard.io/api/2020-01/admin
BOULEVARD_API_KEY=
BOULEVARD_API_SECRET=           # Base64-encoded API secret
BOULEVARD_BUSINESS_ID=
# Optional tuning for phone lookups on large client lists:
# BOULEVARD_PHONE_SCAN_PAGE_SIZE=100
# BOULEVARD_PHONE_SCAN_MAX_PAGES=300

# Optional: business-scoped URL also works:
# https://dashboard.boulevard.io/api/2020-01/<BUSINESS_ID>/admin

# Dev-only safety switch (ignored in production): allow mock member profile when API key is missing
# BOULEVARD_ALLOW_MOCK=true

# ══════════════════════════════════════════════════════════════════
# RECOMMENDED — Degraded functionality without these
# ══════════════════════════════════════════════════════════════════

# SMTP settings for sending session summary emails
# Without these, no email notifications are sent (no PII logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google Sheets — cancellation summary logging
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=    # Paste the entire JSON credential string

# ══════════════════════════════════════════════════════════════════
# OPTIONAL — Have sensible defaults
# ══════════════════════════════════════════════════════════════════

# Email recipients (defaults shown)
# EMAIL_FROM=info@silvermirror.com
# EMAIL_TO=memberships@silvermirror.com
# EMAIL_ESCALATION=hello@silvermirror.com
# EMAIL_REACTION_ALERTS=kristen@silvermirror.com,matt@silvermirror.com,rachael@silvermirror.com,hello@silvermirror.com

# Google Sheet for per-message chat log (all conversations, for QA)
# GOOGLE_CHATLOG_SHEET_ID=

# Google Sheet for booking/payment support incidents (defaults to provided ops sheet if omitted)
# GOOGLE_SUPPORT_INCIDENT_SHEET_ID=15Wame-TJbihEAKEnlL51rhSWRsiVpehz7RO1Gsa9s4c

# QA alert recipient for booking/payment incidents
# EMAIL_QA_ALERT=qatesting@silvermirror.com

# Allowed origin for CORS (your WordPress domain)
ALLOWED_ORIGIN=https://silvermirror.com

# Shared rate limiting (recommended for production on Vercel)
# When Upstash is configured, rate limits are enforced across serverless instances.
# If omitted, the app falls back to in-memory limits on each warm instance.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_BACKEND=auto                  # auto | upstash | memory
# RATE_LIMIT_PREFIX=sm-cancel-bot:ratelimit
# RATE_LIMIT_ANALYTICS=true
# RATE_LIMIT_ENABLE_MEMORY_FALLBACK=true   # keep local protection if Upstash is unavailable
# RATE_LIMIT_TIMEOUT_MS=250
# RATE_LIMIT_FAIL_MODE=open                # default fail behavior when no route override exists
# RATE_LIMIT_SHADOW_MODE=false             # true = observe/log but do not block
#
# Optional route-specific overrides:
# RATE_LIMIT_START_MAX=10
# RATE_LIMIT_MESSAGE_MAX=30
# RATE_LIMIT_TWILIO_WEBHOOK_MAX=120
# RATE_LIMIT_QA_UPGRADE_CHECK_MAX=40
# RATE_LIMIT_QA_UPGRADE_CHECK_FAIL_MODE=closed

# Upgrade / upsell automation tuning (optional, for appointment-gap checks)
# BOULEVARD_APPOINTMENT_SCAN_PAGE_SIZE=100
# BOULEVARD_APPOINTMENT_SCAN_MAX_PAGES=80
# BOULEVARD_UPGRADE_WINDOW_HOURS=6
# YES_RESPONSE_WINDOW_MIN=10
# PREP_BUFFER_30MIN=15
# PREP_BUFFER_50MIN=10
# PREP_BUFFER_90MIN=10
# Optional: remap stale Boulevard location IDs to canonical IDs
# Example: {\"urn:blvd:Location:old\":\"urn:blvd:Location:new\"}
# BOULEVARD_LOCATION_REMAP_JSON=
# Optional: same-store alias groups. Runtime will ignore groups that merge known different storefronts.
# Example: [[\"urn:blvd:Location:id1\",\"urn:blvd:Location:id2\"]]
# BOULEVARD_LOCATION_ALIAS_GROUPS_JSON=

# Enable actual appointment mutation on YES (keep false until service IDs are confirmed)
# BOULEVARD_ENABLE_UPGRADE_MUTATION=false
# BOULEVARD_SERVICE_ID_50MIN=
# BOULEVARD_SERVICE_ID_90MIN=

# Optional auth token for /api/qa/upgrade-check (recommended for production)
# QA_UPGRADE_CHECK_TOKEN=

# Optional auth token for /api/qa/upgrade-check synthetic mode
# QA_SYNTHETIC_MODE_TOKEN=

# Twilio SMS
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# SUPPORT_PHONE=(888) 677-0055
#
# SMS launch mode:
# - pending (default): general Q&A only; upgrade-by-text replies tell guests to call
# - live: enables current SMS upgrade logic
# SMS_UPGRADE_STATUS=pending
#
# SMS outbound automation auth
# SMS_AUTOMATION_TOKEN=

# Klaviyo SMS double opt-in gate (source of truth for outbound SMS eligibility)
# KLAVIYO_PRIVATE_API_KEY=
# KLAVIYO_API_BASE_URL=https://a.klaviyo.com/api
# KLAVIYO_REVISION=2026-01-15
# KLAVIYO_LOOKUP_TIMEOUT_MS=10000
# SMS_REQUIRE_KLAVIYO_OPT_IN=true
# SMS_REQUIRE_MANUAL_LIVE_APPROVAL=true
# SMS_ENABLE_ONE_HOUR_REMINDER=true
# SMS_REMINDER_LEAD_MINUTES=60
# SMS_REMINDER_TOLERANCE_MINUTES=15
# SMS_MAX_CHARS=155
# SMS_WEB_HANDOFF_MESSAGE_LIMIT=10
# SMS_WEB_APP_URL=https://sm-member-cancel.vercel.app/widget

# ══════════════════════════════════════════════════════════════════
# MISSED-CALL AUTOTEXT — Voice pilot infrastructure (VC-1)
# ══════════════════════════════════════════════════════════════════

# Public URL of this deployment. Used to build the <Dial action=...> status
# callback URL emitted from /api/voice/webhook. Must match the host Twilio
# signs against when it posts status callbacks.
# NEXT_PUBLIC_APP_URL=https://sm-member-cancel.vercel.app

# Twilio inbound voice number for each pilot location. The number Twilio
# passes in the "Called" parameter must exactly match (E.164).
# TWILIO_BRICKELL_VOICE_NUMBER=+1786XXXXXXX

# Landline that /api/voice/webhook forwards the inbound call to.
# BRICKELL_LANDLINE=+17868990600

# Dedupe window for status-callback CallSid (status route) and dispatcher
# CallSid (VC-3). Same TTL applies to both so a duplicate status callback
# that arrives after a successful dispatch is still suppressed.
# MISSED_CALL_CALLSID_DEDUPE_TTL_SECONDS=86400

# ══════════════════════════════════════════════════════════════════
# MISSED-CALL AUTOTEXT — Dispatcher gates (VC-3)
# ══════════════════════════════════════════════════════════════════

# Master kill switch for missed-call autotext dispatch. Default is OFF.
# dispatchMissedCallAutotext aborts on Gate 1 unless this is exactly "true".
# MISSED_CALL_AUTOTEXT_ENABLED=false

# JSON array of location slugs enrolled in the pilot. Gate 2 aborts if the
# incoming call's locationCalled is not in this list.
# MISSED_CALL_PILOT_LOCATIONS=["brickell"]

# Per-location send window. Format: "DOWRange HH:MM-HH:MM TZ" segments
# separated by commas. TZ is an IANA zone. Gate 5 aborts if the caller's
# local time is outside every segment. Add MISSED_CALL_SEND_WINDOW_<LOC>
# for each new pilot location.
# MISSED_CALL_SEND_WINDOW_BRICKELL=Mon-Sat 09:00-20:00 America/New_York,Sun 10:00-19:00 America/New_York

# Minutes between two autotexts to the same caller phone (Gate 4 cooldown).
# MISSED_CALL_COOLDOWN_MINUTES=10

# Reply-handling kill switch. When set to "false", inbound replies to
# missed-call sessions receive a static fallback ("Thanks, a teammate
# will follow up soon.") instead of being routed to Claude. The session
# is preserved so observability still works. Default behavior (anything
# other than "false") routes inbound replies through Claude with the
# missed-call prompt. Per spec §1.10.
# MISSED_CALL_REPLY_HANDLING_ENABLED=true

# ══════════════════════════════════════════════════════════════════
# GA4 Measurement Protocol (analytics for the missed-call pilot)
# ══════════════════════════════════════════════════════════════════
# Generated in GA4 console: Admin → Data Streams → Measurement Protocol
# API secrets. Without these, fireGa4Event() logs to console only.
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=
# GA4_DEBUG=1   # optional: post to /debug/mp/collect for validation
# GA4_DISABLE=1 # optional: console-only, no HTTP

